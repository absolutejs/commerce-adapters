{
  "name": "@absolutejs/commerce-stripe",
  "version": "0.18.1-beta.0",
  "description": "Stripe payment + checkout adapter for @absolutejs/commerce",
  "repository": {
    "type": "git",
    "url": "https://github.com/absolutejs/commerce-adapters.git",
    "directory": "stripe"
  },
  "homepage": "https://github.com/absolutejs/commerce-adapters/tree/main/stripe",
  "bugs": {
    "url": "https://github.com/absolutejs/commerce-adapters/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./manifest.json": "./dist/manifest.json"
  },
  "license": "Apache-2.0",
  "author": "Alex Kahn",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/manifest.ts --root ./src --outdir dist --target bun --external @absolutejs/commerce --external stripe && tsc --emitDeclarationOnly --project tsconfig.json && absolute-manifest emit",
    "format": "prettier --write \"./**/*.{js,ts,json,md}\"",
    "release": "bun run build && bun publish --tag beta --access public",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@absolutejs/commerce": "0.30.1-beta.0",
    "@absolutejs/manifest": "^0.1.0",
    "@sinclair/typebox": "^0.34.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "absolutejs": {
    "manifestContract": 1
  }
}
