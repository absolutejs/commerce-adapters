{
  "name": "@absolutejs/commerce-resend",
  "version": "0.19.19-beta.2",
  "description": "Resend transactional-email adapter for @absolutejs/commerce",
  "repository": {
    "type": "git",
    "url": "https://github.com/absolutejs/commerce-adapters.git",
    "directory": "resend"
  },
  "homepage": "https://github.com/absolutejs/commerce-adapters/tree/main/resend",
  "bugs": {
    "url": "https://github.com/absolutejs/commerce-adapters/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./manifest.json": "./dist/manifest.json"
  },
  "license": "Apache-2.0",
  "author": "Alex Kahn",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/manifest.ts --root ./src --outdir dist --target bun --external @absolutejs/commerce --external resend && tsc --emitDeclarationOnly --project tsconfig.json && absolute-manifest emit",
    "format": "prettier --write \"./**/*.{js,ts,json,md}\"",
    "release": "bun run build && bun publish --tag beta --access public",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@absolutejs/manifest": "^0.4.0",
    "@sinclair/typebox": "^0.34.0",
    "resend": "^6.0.0"
  },
  "peerDependencies": {
    "@absolutejs/commerce": ">=0.40.1-beta.1 <0.41"
  },
  "devDependencies": {
    "@absolutejs/commerce": "0.40.1-beta.1",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "absolutejs": {
    "manifestContract": 2
  }
}
